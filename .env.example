# === Configuration du modèle IA (endpoint compatible OpenAI) ===
# URL de base de l'API, SANS le /chat/completions final
# Exemples : https://api.openai.com/v1  |  http://localhost:11434/v1  |  https://mon-serveur/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Nombre max de tokens pour la génération d'un jeu. Prévoir large : les jeux
# complets sont longs ET les modèles à raisonnement (Gemini, o-series…)
# consomment une partie de ce budget pour "réfléchir" avant d'écrire.
OPENAI_MAX_TOKENS=50000

# Raisonnement des modèles "thinking" : none (désactivé — rapide, recommandé
# pour une bonne expérience élève) | low/medium/high (effort limité) |
# default (ne rien envoyer).
# Avec "none", on envoie à la fois le format OpenRouter (reasoning.enabled=false)
# et le format vLLM/SGLang (chat_template_kwargs.enable_thinking=false) ; si le
# serveur rejette ces champs, la requête est automatiquement retentée sans eux.
# NB : même si le serveur ignore tout et "réfléchit" quand même, la réflexion
# (deltas reasoning_content ou balises <think> dans le contenu) est correctement
# séparée du code du jeu — elle ne casse plus le parsing.
OPENAI_REASONING_EFFORT=none

# Température d'échantillonnage (0.6 par défaut : code plus fiable que 0.7+)
OPENAI_TEMPERATURE=0.6

# === Sécurité ===
# Secret pour signer les cookies de session (générer avec : openssl rand -hex 32)
# OBLIGATOIRE en production : le serveur refuse de signer des sessions sans lui.
SESSION_SECRET=change-me-please

# En production, le cookie de session est marqué "secure" (HTTPS uniquement).
# Déploiement en HTTP pur (réseau interne sans TLS) : décommenter la ligne suivante.
# SESSION_SECURE_COOKIE=0

# === Inscription ===
# Code que les élèves doivent saisir pour créer un compte (laisser vide pour inscription libre)
REGISTRATION_CODE=
